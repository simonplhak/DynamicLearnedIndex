{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "cargo",
			"command": "run",
			"problemMatcher": [
				"$rustc"
			],
			"args": [
				"-p",
				"cli_dynamic_learned_index",
				"experiment",
				"example",
				"--dataset",
				"k300",
				"--force"
			],
			"label": "rust: run simple test example"
		},
		{
			"type": "shell",
			"command": "cargo build --release && ./target/release/cli_dynamic_learned_index experiment test_build data/k300 --force --start-from-one",
			"problemMatcher": [
				"$rustc"
			],
			"group": {
                "kind": "build",
            },
			"label": "test build"
		},
		{
			"type": "shell",
			"command": "docker build -t dli-cli .",
			"problemMatcher": [],
			"group": "build",
			"label": "docker: build image"
		},
		{
			"type": "shell",
			"command": "docker run -it --rm -v ${PWD}/experiments_data:/app/experiments_data -v ${PWD}/data:/app/data -v ${PWD}/configs:/app/configs dli-cli test",
			"problemMatcher": [
				"$rustc"
			],
			"group": {
                "kind": "build",
            },
			"label": "docker: test build"
		},
		{
			"type": "shell",
			"command": "sudo docker save dli-cli:latest | ssh xplhak1@cybela13 'docker load'",
			"problemMatcher": [
			],
			"group": {
                "kind": "build",
            },
			"label": "docker: push build"
		},
		{
			"type": "shell",
			"command": "scp -r configs xplhak1@cybela13:configs",
			"problemMatcher": [
			],
			"group": {
                "kind": "build",
            },
			"label": "sync configs with remote"
		},
		{
			"type": "shell",
			"command": "source env/bin/activate && cargo build --release && cd py_dynamic_learned_index && maturin develop --release && python -c 'import py_dynamic_learned_index; print(py_dynamic_learned_index.__version__)'",
			"problemMatcher": [
			],
			"group": {
                "kind": "build",
            },
			"label": "build python package"
		},
	]
}